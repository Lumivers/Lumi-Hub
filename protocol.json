{
  "project": "Lumi-Hub",
  "version": "0.2.0",
  "description": "Lumi-Hub 当前已实现的 WebSocket 协议（Client <-> Host）",
  "architecture": {
    "type": "Monorepo",
    "directories": {
      "client": "Flutter 前端客户端（当前主开发目录）",
      "host": "AstrBot 平台适配器与 WS 服务（Python）",
      "data": "运行期数据目录（MCP 配置、上传文件等）",
      "docs": "开发文档与日志（多数为本地记录）"
    }
  },
  "envelope": {
    "message_id": "string (请求/响应关联 ID)",
    "type": "string (消息类型)",
    "source": "enum: client | host",
    "target": "enum: client | host",
    "timestamp": "integer (UNIX 毫秒时间戳)",
    "payload": "object (按 type 变化)"
  },
  "message_types": {
    "connection": [
      "CONNECT",
      "PING",
      "PONG"
    ],
    "chat": [
      "CHAT_REQUEST",
      "CHAT_STREAM_CHUNK",
      "CHAT_RESPONSE",
      "CHAT_RESPONSE_END"
    ],
    "auth": [
      "AUTH_REGISTER",
      "AUTH_LOGIN",
      "AUTH_RESTORE",
      "AUTH_REQUIRED",
      "AUTH_RESPONSE"
    ],
    "history": [
      "HISTORY_REQUEST",
      "HISTORY_RESPONSE"
    ],
    "persona": [
      "PERSONA_LIST",
      "PERSONA_SWITCH",
      "PERSONA_CLEAR_HISTORY",
      "PERSONA_CLEAR_HISTORY_RESPONSE",
      "PERSONA_DELETE",
      "PERSONA_DELETE_RESPONSE"
    ],
    "mcp_config": [
      "MCP_CONFIG_GET",
      "MCP_CONFIG_RESPONSE",
      "MCP_CONFIG_UPDATE",
      "MCP_CONFIG_UPDATE_RESPONSE"
    ],
    "file_upload": [
      "FILE_UPLOAD_INIT",
      "FILE_UPLOAD_CHUNK",
      "FILE_UPLOAD_COMPLETE",
      "FILE_UPLOAD_ACK",
      "FILE_UPLOAD_ERROR"
    ],
    "system": [
      "ERROR_ALERT"
    ]
  },
  "examples": {
    "CHAT_REQUEST": {
      "message_id": "msg-001",
      "type": "CHAT_REQUEST",
      "source": "client",
      "target": "host",
      "timestamp": 1700000000000,
      "payload": {
        "content": "帮我看一下这个报错",
        "context_id": "default",
        "persona_id": "default",
        "attachments": []
      }
    },
    "CHAT_STREAM_CHUNK": {
      "message_id": "msg-001",
      "type": "CHAT_STREAM_CHUNK",
      "source": "host",
      "target": "client",
      "timestamp": 1700000000200,
      "payload": {
        "delta": "正在分析",
        "persona": "default"
      }
    },
    "AUTH_REQUIRED": {
      "message_id": "msg-auth-01",
      "type": "AUTH_REQUIRED",
      "source": "host",
      "target": "client",
      "timestamp": 1700000001000,
      "payload": {
        "task_id": "task-789",
        "action_type": "FILE_MODIFY",
        "risk_level": "HIGH",
        "target_path": "E:/Lumi-Hub/readme.md",
        "description": "准备修改文件",
        "diff_preview": "...",
        "tool_name": "search_replace",
        "timeout_seconds": 30
      }
    },
    "AUTH_RESPONSE": {
      "message_id": "msg-auth-01",
      "type": "AUTH_RESPONSE",
      "source": "client",
      "target": "host",
      "timestamp": 1700000001200,
      "payload": {
        "task_id": "task-789",
        "decision": "APPROVED",
        "reason": ""
      }
    },
    "FILE_UPLOAD_INIT": {
      "message_id": "upload-001",
      "type": "FILE_UPLOAD_INIT",
      "source": "client",
      "target": "host",
      "timestamp": 1700000010000,
      "payload": {
        "file_name": "demo.pdf",
        "mime_type": "application/pdf",
        "size_bytes": 102400,
        "sha256": "<hex>"
      }
    },
    "FILE_UPLOAD_ACK_COMPLETE": {
      "message_id": "upload-001",
      "type": "FILE_UPLOAD_ACK",
      "source": "host",
      "target": "client",
      "timestamp": 1700000011200,
      "payload": {
        "phase": "complete",
        "upload_id": "2a9b...",
        "status": "success",
        "attachment": {
          "id": 123,
          "file_name": "demo.pdf",
          "storage_path": "uploads/user_1/2026/03/25/2a9b_demo.pdf",
          "mime_type": "application/pdf",
          "size_bytes": 102400,
          "sha256": "<hex>"
        }
      }
    },
    "MCP_CONFIG_UPDATE": {
      "message_id": "mcp-001",
      "type": "MCP_CONFIG_UPDATE",
      "source": "client",
      "target": "host",
      "timestamp": 1700000020000,
      "payload": {
        "config": {
          "mcpServers": {
            "notion": {
              "command": "npx",
              "args": [
                "-y",
                "mcp-remote",
                "https://mcp.notion.com/mcp"
              ],
              "env": {
                "NOTION_API_TOKEN": "${NOTION_API_TOKEN}"
              }
            }
          }
        }
      }
    }
  },
  "notes": [
    "本文件只描述当前代码中已实现并在运行中的消息类型。",
    "历史规划中的 TASK_EXECUTE / TASK_STATUS_UPDATE / UNDO_REQUEST 等类型暂未实现，故已移除。",
    "source/target 当前只有 client 与 host 两端。"
  ]
}
